{
  "type": "page",
  "title": "Kubeconfig 管理",
  "body": [
    {
      "type": "crud",
      "api": "get:/mgm/plugins/kubeconfig_export/templates",
      "columns": [
        {
          "name": "id",
          "label": "ID"
        },
        {
          "name": "display_name",
          "label": "显示名称"
        },
        {
          "name": "cluster",
          "label": "集群名称"
        },
        {
          "name": "server",
          "label": "API 服务器"
        },
        {
          "name": "user",
          "label": "用户"
        },
        {
          "name": "namespace",
          "label": "命名空间"
        },
        {
          "name": "is_aws_eks",
          "label": "AWS EKS",
          "type": "mapping",
          "map": {
            "true": "是",
            "false": "否"
          }
        },
        {
          "name": "created_at",
          "label": "创建时间",
          "type": "datetime"
        },
        {
          "name": "updated_at",
          "label": "更新时间",
          "type": "datetime"
        }
      ],
      "headerToolbar": [
        "reload"
      ],
      "itemActions": [
        {
          "type": "button",
          "label": "导出 Kubeconfig",
          "level": "primary",
          "icon": "fa-solid fa-download",
          "actionType": "ajax",
          "api": {
            "method": "get",
            "url": "/mgm/plugins/kubeconfig_export/kubeconfig/${id}/export",
            "dataType": "blob",
            "downloadName": "${cluster}-kubeconfig.yaml"
          }
        },
        {
          "type": "button",
          "label": "高级导出",
          "level": "default",
          "icon": "fa-solid fa-gear",
          "actionType": "dialog",
          "dialog": {
            "title": "高级导出 - 指定命名空间",
            "size": "md",
            "body": {
              "type": "form",
              "controls": [
                {
                  "type": "text",
                  "name": "namespace",
                  "label": "限制命名空间",
                  "placeholder": "可选，留空则无限制",
                  "clearable": true
                },
                {
                  "type": "text",
                  "name": "role",
                  "label": "角色",
                  "placeholder": "admin, edit, view 等（暂未实现）",
                  "clearable": true
                }
              ],
              "actions": [
                {
                  "type": "button",
                  "label": "导出",
                  "level": "primary",
                  "actionType": "ajax",
                  "api": {
                    "method": "get",
                    "url": "/mgm/plugins/kubeconfig_export/kubeconfig/${id}/export?namespace=${namespace}&role=${role}",
                    "dataType": "blob",
                    "downloadName": "${cluster}-${namespace||default}-kubeconfig.yaml"
                  }
                }
              ]
            }
          }
        }
      ]
    }
  ]
}